{
    "name": "web-notebook",
    "displayName": "Web Notebook",
    "description": "A notebook renderer for basic web code (HTML/CSS/JavaScript)",
    "version": "1.0.0",
    "publisher": "oney",
    "repository": {
        "type": "git",
        "url": "https://github.com/soney/vscode-webnb.git"
    },
    "license": "MIT",
    "engines": {
        "vscode": "^1.117.0",
        "node": "^22.18.0 || >=24.11.0"
    },
    "keywords": [
        "notebookRenderer",
        "notebookKernelWebNotebook"
    ],
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onNotebook:web-notebook",
        "onLanguage:webnb",
        "onStartupFinished"
    ],
    "main": "./out/extension/extension.js",
    "browser": "./out/extension/extension.web.js",
    "extensionKind": [
        "workspace"
    ],
    "contributes": {
        "notebooks": [
            {
                "id": "web-notebook",
                "type": "web-notebook",
                "displayName": "Web Notebook",
                "selector": [
                    {
                        "filenamePattern": "*.webnb"
                    }
                ]
            }
        ],
        "notebookRenderer": [
            {
                "id": "practical-javascript-reading-notebook",
                "entrypoint": "./out/client/index.js",
                "displayName": "practical-javascript-reading-notebook",
                "requiresMessaging": "optional",
                "mimeTypes": [
                    "x-application/webnb-output"
                ]
            },
            {
                "id": "webnb-markdown-image-size",
                "displayName": "Web Notebook image sizing",
                "entrypoint": {
                    "extends": "vscode.markdown-it-renderer",
                    "path": "./out/markdownItPlugin/index.js"
                }
            }
        ],
        "languages": [
            {
                "id": "webnb",
                "extensions": [
                    ".webnb"
                ],
                "icon": {
                    "light": "./icons/webnb-icon.svg",
                    "dark": "./icons/webnb-icon.svg"
                }
            }
        ],
        "commands": [
            {
                "command": "webnb.focusSingleFile",
                "title": "Focus on a single file"
            }
        ],
        "configuration": {
            "title": "Web-Notebook",
            "properties": {}
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "webpack --mode production",
        "compile-dev": "webpack --mode development",
        "lint": "eslint src",
        "watch": "webpack --mode development --watch",
        "pretest": "webpack --mode development && npm run lint",
        "test-web": "node scripts/vscode-test-web.js samplenotebooks/sample.webnb",
        "in-browser": "npm run compile-dev && node scripts/vscode-test-web.js samplenotebooks/sample.webnb",
        "in-browser:open": "node scripts/vscode-test-web.js samplenotebooks/sample.webnb",
        "in-browser:watch": "node scripts/vscode-test-web.js samplenotebooks/sample.webnb --watch",
        "in-browser:remote": "node scripts/vscode-test-web.js samplenotebooks/sample.webnb --watch --remote",
        "dev:web": "npm run watch",
        "test": "vscode-test",
        "gen-vsix": "npm run compile && vsce package -o web-notebook.vsix",
        "coursera:import": "node scripts/coursera-docker-dev.js import",
        "coursera:start": "node scripts/coursera-docker-dev.js start",
        "coursera:stop": "node scripts/coursera-docker-dev.js stop",
        "preview": "vite --config preview/vite.config.ts"
    },
    "devDependencies": {
        "@codemirror/commands": "^6.10.4",
        "@codemirror/lang-css": "^6.3.1",
        "@codemirror/lang-html": "^6.4.11",
        "@codemirror/lang-javascript": "^6.2.5",
        "@codemirror/lang-markdown": "^6.5.0",
        "@codemirror/state": "^6.7.1",
        "@codemirror/theme-one-dark": "^6.1.3",
        "@codemirror/view": "^6.43.6",
        "@types/babel__standalone": "^7.1.9",
        "@types/mocha": "^10.0.10",
        "@types/node": "26.x",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@types/vscode": "~1.116.0",
        "@types/vscode-notebook-renderer": "^1.72.4",
        "@types/webpack-env": "^1.18.8",
        "@typescript-eslint/eslint-plugin": "^8.63.0",
        "@typescript-eslint/parser": "^8.63.0",
        "@vscode/test-cli": "^0.0.15",
        "@vscode/test-electron": "^3.0.0",
        "@vscode/test-web": "^0.0.81",
        "@vscode/vsce": "^3.9.2",
        "chokidar": "^5.0.0",
        "codemirror": "^6.0.2",
        "css-loader": "^7.1.4",
        "eslint": "^10.6.0",
        "fork-ts-checker-webpack-plugin": "^9.1.0",
        "gh-pages": "^6.3.0",
        "glob": "^13.0.6",
        "mocha": "^11.7.6",
        "style-loader": "^4.0.0",
        "ts-loader": "^9.6.2",
        "typescript": "^6.0.3",
        "util": "^0.12.5",
        "vite": "^8.1.3",
        "vscode-notebook-error-overlay": "^1.1.0",
        "webpack": "^5.108.4",
        "webpack-cli": "^7.2.1",
        "yarn": "^1.22.22"
    },
    "dependencies": {
        "@babel/standalone": "^8.0.3",
        "@xterm/xterm": "^6.0.0",
        "marked": "^18.0.5",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "smartypants": "^0.2.2"
    }
}
