{
    "name": "web-notebook",
    "displayName": "Web Notebook",
    "description": "A notebook renderer for basic web code (HTML/CSS/JavaScript)",
    "version": "0.0.2",
    "publisher": "oney",
    "repository": {
        "type": "git",
        "url": "https://github.com/soney/vscode-webnb.git"
    },
    "license": "MIT",
    "engines": {
        "vscode": "^1.97.2"
    },
    "keywords": [
        "notebookRenderer",
        "notebookKernelWebNotebook"
    ],
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onNotebook:web-notebook",
        "onStartupFinished"
    ],
    "main": "./out/extension/extension.js",
    "browser": "./out/extension/extension.web.js",
    "contributes": {
        "notebooks": [
            {
                "id": "web-notebook",
                "type": "web-notebook",
                "displayName": "Web Notebook",
                "selector": [
                    {
                        "filenamePattern": "*.webnb"
                    }
                ]
            }
        ],
        "notebookRenderer": [
            {
                "id": "practical-javascript-reading-notebook",
                "entrypoint": "./out/client/index.js",
                "displayName": "practical-javascript-reading-notebook",
                "requiresMessaging": "optional",
                "mimeTypes": [
                    "x-application/webnb-output"
                ]
            }
        ],
        "languages": [
            {
                "id": "webnb",
                "extensions": [
                    ".webnb"
                ],
                "icon": {
                    "light": "./icons/webnb-icon.svg",
                    "dark": "./icons/webnb-icon.svg"
                }
            }
        ],
        "commands": [
            {
                "command": "webnb.focusSingleFile",
                "title": "Focus on a single file"
            }
        ],
        "configuration": {
            "title": "Web-Notebook",
            "properties": {}
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "webpack --mode production",
        "compile-dev": "webpack --mode development",
        "lint": "eslint src",
        "watch": "webpack --mode development --watch",
        "pretest": "webpack --mode development && npm run lint",
        "test-web": "node scripts/vscode-test-web.js samplenotebooks/sample.webnb",
        "in-browser": "npm run compile-dev && node scripts/vscode-test-web.js samplenotebooks/sample.webnb",
        "in-browser:open": "node scripts/vscode-test-web.js samplenotebooks/sample.webnb",
        "in-browser:watch": "node scripts/vscode-test-web.js samplenotebooks/sample.webnb --watch",
        "dev:web": "npm run watch",
        "test": "vscode-test",
        "gen-vsix": "npx vsce package -o web-notebook.vsix"
    },
    "devDependencies": {
        "@types/babel__standalone": "^7.1.9",
        "@types/marked": "^5.0.2",
        "@types/mocha": "^10.0.10",
        "@types/node": "20.x",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/vscode": "^1.97.0",
        "@types/vscode-notebook-renderer": "^1.72.3",
        "@types/webpack-env": "^1.18.8",
        "@typescript-eslint/eslint-plugin": "^8.22.0",
        "@typescript-eslint/parser": "^8.22.0",
        "@vscode/test-cli": "^0.0.10",
        "@vscode/test-electron": "^2.4.1",
        "@vscode/test-web": "^0.0.80",
        "chokidar": "^3.6.0",
        "css-loader": "^7.1.2",
        "eslint": "^9.19.0",
        "fork-ts-checker-webpack-plugin": "^9.0.2",
        "gh-pages": "^6.3.0",
        "glob": "^11.0.1",
        "mocha": "^11.1.0",
        "style-loader": "^4.0.0",
        "ts-loader": "^9.5.2",
        "typescript": "^5.7.3",
        "util": "^0.12.5",
        "vscode-notebook-error-overlay": "^1.1.0",
        "webpack": "^5.97.1",
        "webpack-cli": "^6.0.1",
        "yarn": "^1.22.22"
    },
    "dependencies": {
        "@babel/standalone": "^7.27.6",
        "@xterm/xterm": "^5.5.0",
        "marked": "^17.0.5",
        "react": "^18.3.1",
        "react-dom": "^18.3.1"
    }
}
